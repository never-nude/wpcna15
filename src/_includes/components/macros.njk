{% macro eventCard(event, featured=false, initiallyHidden=false) %}
  <article
    class="event-card"
    data-event-card
    data-category="{{ event.category }}"
    data-month="{{ event.monthKey }}"
    data-status="{{ event.status }}"
    data-start-date="{{ event.startDate }}"
    data-end-date="{{ event.endDate or event.startDate }}"
    data-start-time="{{ event.startTime or '' }}"
    data-end-time="{{ event.endTime or '' }}"
    data-search="{{ event.searchText }}"
    {% if initiallyHidden %}hidden{% endif %}
  >
    {% if featured and event.displayImage %}
      <a class="event-card-img" href="{{ event.detailUrl | withPrefix }}" aria-hidden="true" tabindex="-1">
        <img src="{{ event.displayImage | withPrefix }}" alt="" loading="lazy">
      </a>
    {% endif %}
    <div class="event-card-body">
      <div class="event-card-top">
        <span class="tag">{{ event.category }}</span>
        {% if event.status == "past" %}
          <span class="tag tag-muted">Past</span>
        {% endif %}
      </div>
      <h3><a href="{{ event.detailUrl | withPrefix }}">{{ event.title }}</a></h3>
      <p class="event-card-date">{{ event | shortDateLabel }}</p>
      <div class="event-card-meta">
        <span>{{ event | timeLabel }}</span>
        <span>{{ event.locationName }}</span>
      </div>
      <p class="event-card-summary">{{ event.shortSummary }}</p>
      <div class="event-card-actions">
        <a class="btn btn-primary" href="{{ event.detailUrl | withPrefix }}" aria-label="View details for {{ event.title }}">Details</a>
      </div>
    </div>
  </article>
{% endmacro %}

{% macro postingCard(posting) %}
  <article
    class="event-card posting-card"
    data-posting-card
    data-month="{{ posting.monthKey }}"
    data-status="{{ posting.status }}"
  >
    <div class="event-card-body">
      {% if posting.category or posting.status == "past" %}
        <div class="event-card-top">
          {% if posting.category %}
            <span class="tag">{{ posting.category }}</span>
          {% endif %}
          {% if posting.status == "past" %}
            <span class="tag tag-muted">Past</span>
          {% endif %}
        </div>
      {% endif %}
      <h3><a href="{{ posting.detailUrl | withPrefix }}">{{ posting.title }}</a></h3>
      <p class="event-card-date">{{ posting | shortDateLabel }}</p>
      <div class="event-card-meta">
        <span>{{ posting.displayTime or (posting | timeLabel) }}</span>
        <span>{{ posting.locationName }}</span>
      </div>
      <p class="event-card-summary">{{ posting.shortSummary }}</p>
      <div class="event-card-actions">
        <a class="btn btn-primary" href="{{ posting.detailUrl | withPrefix }}" aria-label="View posting details for {{ posting.title }}">{{ posting.cardActionLabel or "Posting details" }}</a>
      </div>
    </div>
  </article>
{% endmacro %}

{% macro resourceCard(resource) %}
  {% set isExternal = resource.url.startsWith("http") %}
  {% set href = resource.url if isExternal else (resource.url | withPrefix) %}
  <article class="resource-card">
    <p class="eyebrow">{{ resource.eyebrow }}</p>
    <h3>{{ resource.title }}</h3>
    <p>{{ resource.summary }}</p>
    <a class="link-arrow" href="{{ href }}"{% if isExternal %} target="_blank" rel="noopener"{% endif %} aria-label="{{ resource.ctaLabel }}: {{ resource.title }}">{{ resource.ctaLabel }}</a>
  </article>
{% endmacro %}

{% macro neighborhoodCard(neighborhood, compact=true, guideMode=false) %}
  <article class="neighborhood-card">
    {% if neighborhood.detailUrl %}
      <a href="{{ neighborhood.detailUrl | withPrefix }}" aria-label="Open {{ neighborhood.name }} profile">
    {% else %}
      <div class="neighborhood-card-static" role="group" aria-label="{{ neighborhood.name }} profile coming soon">
    {% endif %}
      {% if (guideMode and neighborhood.guidePlaceholder) or neighborhood.profilePlaceholder %}
        <span class="neighborhood-card-img neighborhood-card-placeholder" aria-label="{{ neighborhood.guideImageLabel }}">
          <span>{{ neighborhood.guideImageLabel }}</span>
        </span>
      {% elif neighborhood.hero %}
        <span class="neighborhood-card-img">
          <img src="{{ (neighborhood.hero.cardImagePath or neighborhood.hero.imagePath) | withPrefix }}" alt="{{ neighborhood.hero.cardAltText or neighborhood.hero.altText }}" loading="lazy">
        </span>
      {% endif %}
      <span class="neighborhood-card-body{% if guideMode %} neighborhood-card-body-simple{% endif %}">
        {% if not guideMode %}
          <p class="neighborhood-card-group">{{ neighborhood.group }}</p>
        {% endif %}
        <h3>{{ neighborhood.name }}</h3>
        {% if not guideMode %}
          <p class="neighborhood-card-teaser">{{ neighborhood.guideDescription if neighborhood.profilePlaceholder else neighborhood.teaser }}</p>
          {% if neighborhood.detailUrl %}
            <span class="neighborhood-card-cta">View neighborhood</span>
          {% else %}
            <span class="neighborhood-card-cta neighborhood-card-cta-muted">Profile coming soon</span>
          {% endif %}
        {% endif %}
      </span>
    {% if neighborhood.detailUrl %}
      </a>
    {% else %}
      </div>
    {% endif %}
  </article>
{% endmacro %}
