---
layout: layouts/base.njk
title: What's Happening in White Plains
metaDescription: A neighborhood-centered guide to events, civic life, and useful local information around White Plains.
---
{% from "components/macros.njk" import eventCard, neighborhoodCard, resourceCard %}

<section class="hero hero-home">
  <img src="{{ site.heroImage | withPrefix }}" alt="{{ site.heroImageAlt }}" loading="eager">
  <div class="hero-overlay">
    <div class="wrap">
      <p class="eyebrow">White Plains, New York</p>
      <h1>What's happening in White Plains</h1>
      <p>Events, neighborhoods, and civic life in the county seat of Westchester.</p>
      <p class="hero-note">{{ site.mission }}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="{{ '/events/' | withPrefix }}">See what's happening</a>
        <a class="btn btn-outline" href="{{ '/neighborhoods/' | withPrefix }}">Neighborhoods</a>
      </div>
      <ul class="hero-stats">
        <li><span>Upcoming</span><strong>{{ eventStore.upcoming.length }} events</strong></li>
        <li><span>Neighborhoods</span><strong>{{ neighborhoodStore.count }}</strong></li>
        <li><span>Sources</span><strong>City, Library, BID, WPPAC</strong></li>
      </ul>
    </div>
  </div>
</section>

<section class="section-compact home-gallery-section">
  <div class="wrap">
    <div class="section-header home-gallery-header">
      <div>
        <p class="eyebrow">White Plains</p>
        <h2>A closer look at the city</h2>
        <p>Views pulled from the older WPCNA site, carried forward here so the homepage feels rooted in the place it serves.</p>
      </div>
    </div>
    <div class="home-gallery-grid" aria-label="White Plains photo gallery">
      {% for photo in site.homeGallery %}
        {% if not loop.first %}
          <figure class="home-gallery-card{% if loop.index == 2 %} home-gallery-card-wide{% endif %}">
            <img src="{{ photo.src | withPrefix }}" alt="{{ photo.alt }}" loading="lazy">
            <figcaption>{{ photo.label }}</figcaption>
          </figure>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="section-header">
      <div>
        <p class="eyebrow">Coming Up</p>
        <h2>Upcoming events</h2>
        <p>A curated selection of public meetings, arts events, downtown happenings, and neighborhood programs.</p>
      </div>
      <a class="link-arrow" href="{{ '/events/' | withPrefix }}">See all happenings</a>
    </div>

    {% if eventStore.homeUpcoming.length %}
      <div class="card-grid">
        {% for event in eventStore.homeUpcoming %}
          {{ eventCard(event, true) }}
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">
        <h3>No upcoming events right now.</h3>
        <p>Check back soon or browse past events.</p>
        <a class="btn btn-primary" href="{{ '/events/' | withPrefix }}">Browse what's happening</a>
      </div>
    {% endif %}
  </div>
</section>

<section class="section section-alt">
  <div class="wrap">
    <div class="section-header">
      <div>
        <p class="eyebrow">Neighborhoods</p>
        <h2>Explore White Plains</h2>
        <p>{{ neighborhoodStore.count }} neighborhoods from Downtown to Saxon Woods.</p>
      </div>
      <a class="link-arrow" href="{{ '/neighborhoods/' | withPrefix }}">All neighborhoods</a>
    </div>
    <div class="carousel-header">
      <span class="archive-count">{{ neighborhoodStore.count }} neighborhoods</span>
      <div class="carousel-controls">
        <button class="carousel-btn" type="button" data-carousel-prev aria-label="Previous">&larr;</button>
        <button class="carousel-btn" type="button" data-carousel-next aria-label="Next">&rarr;</button>
      </div>
    </div>
    <div class="carousel-track" data-carousel-track>
      {% for neighborhood in neighborhoodStore.all %}
        {{ neighborhoodCard(neighborhood) }}
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="section-header">
      <div>
        <p class="eyebrow">Quick Links</p>
        <h2>Useful pages</h2>
        <p>Helpful pages for following meetings, sharing updates, and getting oriented around White Plains.</p>
      </div>
    </div>
    <div class="card-grid card-grid-2">
      {% for resource in resources %}
        {{ resourceCard(resource) }}
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="wrap">
    <div class="spotlight">
      <div>
        <p class="eyebrow">About</p>
        <h2>Neighborhood voices, citywide view</h2>
        <p><strong>WPCNA</strong> &mdash; the <strong>White Plains Council of Neighborhood Associations</strong> &mdash; brings neighborhood associations together, shares information across the city, and helps residents keep track of what matters in White Plains. {{ site.purpose }}</p>
        <p style="margin-top:1rem"><a class="btn btn-primary" href="{{ '/about/' | withPrefix }}">About WPCNA</a></p>
      </div>
      <div class="spotlight-card">
        <p class="eyebrow">Contact</p>
        <h3>Contact WPCNA</h3>
        <p>{{ site.location }}</p>
        <p>{{ site.meetingNote }}</p>
        <a class="btn btn-outline" href="{{ '/about/#contact-form' | withPrefix }}" style="margin-top:0.75rem">Get in touch</a>
      </div>
    </div>
  </div>
</section>
